    "# Data handling\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "\n",
    "#required import for geopandas (as we are using it), that was not auto installed as a dependency\n",
    "import pyarrow\n",
    "\n",
    "# Data reading\n",
    "import requests\n",
    "from io import BytesIO, StringIO\n",
    "\n",
    "# Data visualization\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
